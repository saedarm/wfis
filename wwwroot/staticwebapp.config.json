{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/*",
      "/sounds/*",
      "/css/*",
      "/_framework/*",
      "/*.js",
      "/*.css",
      "/*.png",
      "/*.ico",
      "/*.svg",
      "/*.geojson",
      "/*.json"
    ]
  },
  "globalHeaders": {
    "cache-control": "no-cache"
  },
  "mimeTypes": {
    ".dll": "application/octet-stream",
    ".wasm": "application/wasm",
    ".blat": "application/octet-stream",
    ".dat": "application/octet-stream"
  }
}
